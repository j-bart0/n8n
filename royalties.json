    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nconst firstRow = items[0].json;\nconst statementTotal = parseFloat(firstRow['Statement Total in USD']) || 0;\nconst openingBalance = parseFloat(firstRow['Opening Balance in USD']) || 0;\nconst closingBalance = parseFloat(firstRow['Closing Balance in USD']) || 0;\n\nconst aggregated = {};\n\nfor (const item of items) {\n  const row = item.json;\n  if (!row['ISRC'] || !row['Service']) continue;\n\n  const key = row['ISRC'];\n\n  if (!aggregated[key]) {\n    aggregated[key] = {\n      statementPeriod:  row['Statement Period'],\n      isrc:             row['ISRC'],\n      trackTitle:       row['Track Title'],\n      releaseTitle:     row['Release Title'],\n      upc:              row['UPC'],\n      artist:           row['Artist'],\n      streams:          0,\n      revenueUSD:       0,\n      services:         [],\n      statementTotal,\n      openingBalance,\n      closingBalance,\n    };\n  }\n\n  const entry = aggregated[key];\n  entry.streams    += parseInt(row['Quantity']) || 0;\n  entry.revenueUSD += parseFloat(row['Amount Due in USD']) || 0;\n\n  if (row['Service'] && !entry.services.includes(row['Service'])) {\n    entry.services.push(row['Service']);\n  }\n}\n\nreturn Object.values(aggregated).map(entry => ({\n  json: {\n    ...entry,\n    revenueUSD:  Math.round(entry.revenueUSD * 1000000) / 1000000,\n    services:    entry.services.join(', '),\n    notionTitle: entry.trackTitle,\n  }\n}));"
      },
