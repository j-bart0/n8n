      "parameters": {
        "jsCode": "const items = $input.all();\nconst existing = items[0].json;\nconst newData = $('Code in JavaScript').item.json;\n\nconst prevTotalStreams  = Number(existing.property_total_streams)  || 0;\nconst prevTotalRevenue = Number(existing.property_total_revenue_usd) || 0;\nconst lastPeriodRev    = Number(existing.property_last_period_revenue) || 0;\nconst newPeriodRev     = Number(newData.revenueUSD) || 0;\n\nconst newTotalStreams  = prevTotalStreams + (Number(newData.streams) || 0);\nconst newTotalRevenue = Math.round((prevTotalRevenue + newPeriodRev) * 1000000) / 1000000;\n\nlet deltaPercent = null;\nif (lastPeriodRev > 0) {\n  deltaPercent = Math.round(((newPeriodRev - lastPeriodRev) / lastPeriodRev) * 10000) / 100;\n}\n\nreturn [\n  {\n    json: {\n      pageId:              String(existing.id || ''),\n      newTotalStreams:      newTotalStreams,\n      newTotalRevenue:     newTotalRevenue,\n      prevPeriodRevenue:   lastPeriodRev,\n      lastPeriodRevenue:   newPeriodRev,\n      deltaPercent:        deltaPercent,\n      lastStatementPeriod: String(newData.statementPeriod || ''),\n      services:            String(newData.services || ''),\n    }\n  }\n];"
      },
