      "parameters": {
        "jsCode": "const items = $input.all();\n\nconst count = items.length;\n\nconst seen = new Set();\nconst unique = [];\n\nfor (const item of items) {\n  const subject = item.json.headers?.Subject || item.json.subject || '';\n  if (!seen.has(subject)) {\n    seen.add(subject);\n    unique.push(item);\n  }\n}\n\nunique.sort((a, b) => {\n  const dateA = parseInt(a.json.internalDate || '0');\n  const dateB = parseInt(b.json.internalDate || '0');\n  return dateA - dateB;\n});\n\nif (unique.length === 0) {\n  return [{ json: { debug: true, inputCount: count, outputCount: 0, firstSubject: items[0]?.json?.headers?.Subject || 'nessuno' } }];\n}\n\nreturn unique.map(item => ({\n  json: item.json,\n  binary: item.binary\n}));"
      },
